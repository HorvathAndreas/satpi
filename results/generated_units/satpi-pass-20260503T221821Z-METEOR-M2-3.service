[Unit]
Description=SATPI pass receiver for METEOR-M2 3 (south_to_north) at 2026-05-03T22:18:21Z
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=andreas
WorkingDirectory=/home/andreas/satpi
ExecStart=/usr/bin/python3 /home/andreas/satpi/bin/receive_pass.py --pass-file /home/andreas/satpi/results/generated_units/satpi-pass-20260503T221821Z-METEOR-M2-3.pass.json
