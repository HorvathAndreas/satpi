; ==========================================
; SATPI CONFIGURATION
; ==========================================

[station]
name = satpi5
timezone = Europe/Zurich

[qth]
latitude = 47.570123
longitude = 8.948649
altitude_m = 448

[paths]
base_dir = /home/andreas/satpi
pass_file = results/passes/passes.json
log_dir = logs
output_dir = results/captures
generated_units_dir = systemd/generated

tle_file = results/tle/weather.tle
optimization_dir = results/optimization
optimization_ai_report_file = results/optimization/optimization-report-ai.txt
reception_db_file = results/database/reception.db

satdump_bin = /usr/bin/satdump
mail_bin = /usr/bin/msmtp
python_bin = /usr/bin/python3

[hardware]
source_id = 00000001
gain = 38.6
sample_rate = 2.4e6
bias_t = false

[satellite.METEOR-M2 3]
enabled = true
norad_id = 40014
min_elevation_deg = 30
frequency = 137.9 MHz
bandwidth = 1 MHz
pipeline = meteor_m2-x_lrpt
pass_direction = all

[satellite.METEOR-M2 4]
enabled = true
norad_id = 40015
min_elevation_deg = 30
frequency = 137.9 MHz
bandwidth = 1 MHz
pipeline = meteor_m2-x_lrpt
pass_direction = all

[scheduling]
pass_update_frequency = DAILY
pass_update_time = 00:00
pass_update_weekday = MONDAY
pre_start_seconds = 120
post_stop_seconds = 120
pass_max_prediction_hours = 168

[network]
; tle_url = https://celestrak.org/NORAD/elements/gp.php?GROUP=weather&FORMAT=tle
tle_url = https://api.n2yo.com/rest/v1/satellite/tle/25544/
tle_timeout_seconds = 30
api_key = TKTJPH-88CQZ9-26N3TL-5Q9D
tle_format = JSON

[decode]
min_cadu_size_bytes = 1048576
success_dir_relpath = MSU-MR

[copytarget]
enabled = true
type = rclone
rclone_remote = dropbox
rclone_path = satpi5
create_link = true

[notify]
enabled = true
mail_to = info@andreas-horvath.ch
mail_subject_prefix = SATPI5

[systemd]
service_user = andreas

[reception_setup]
antenna_type = Diamond DPKE-137 QFH
antenna_location = garden rail east corner 2m aluminum mast
antenna_orientation = vertical
lna = n/a
rf_filter = n/a
feedline = 3m
sdr = RTL-SDR V4
raspberry_pi = Raspberry Pi 5
power_supply = Delock Keystone next to Raspberry Pi and RTL-SDR
additional_info = split sdr and raspberry pi/psu in to housing

[optimize_reception]
enabled = true
max_delta_aos_azimuth = 20.0
max_delta_los_azimuth = 20.0
max_delta_culmination_azimuth = 20.0
max_delta_culmination_elevation = 10.0
elevation_band_1_max = 20
elevation_band_2_max = 35
elevation_band_3_max = 50
elevation_band_4_max = 65
elevation_band_5_max = 80
output_dir = /home/andreas/satpi/results/reports

[optimize_reception_ai]
enabled = true
max_passes = 25
model = gpt-5
include_optimizer_report = true
temperature = 1.0
api_key = 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

[noise_floor]
measurement_duration = 600
schedule_minute = 30
; Centre frequency and bandwidth of the monitored signal
center_freq = 137.9 MHz
bandwidth = 0.4 MHz
bin_size = 10 kHz
; Optional: explicit start/end override center+bandwidth if set
; freq_start = 137.7 Mhz
; freq_end_mhz   = 138.1 Mhz
upload_enabled = true
rclone_remote = dropbox
rclone_path = satpi5/reports
create_link = false
